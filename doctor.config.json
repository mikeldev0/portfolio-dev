{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "files": [".agents/**"],
    "overrides": [
      {
        "files": ["public/i18n.js"],
        "rules": ["deslop/unused-file"]
      },
      {
        "files": ["package.json"],
        "rules": ["deslop/unused-dependency", "deslop/unused-dev-dependency"]
      },
      {
        "files": ["pnpm-workspace.yaml"],
        "rules": ["react-doctor/require-pnpm-hardening"]
      },
      {
        "files": ["src/components/ScrollLinkedAvatar.tsx"],
        "rules": ["react-doctor/no-initialize-state"]
      }
    ]
  }
}
