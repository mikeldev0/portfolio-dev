---
import AboutMe from "../components/AboutMe.astro";
import Experiences from "../components/Experiences.astro";
import Footer from "../components/Footer.astro";
import Projects from "../components/Projects.astro";
import ScrollTopButton from "../components/ScrollTopButton.astro";
import SectionContainer from "../components/SectionContainer.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import LinkedInIcon from "../icons/LinkedInIcon.astro";
import MailIcon from "../icons/MailIcon.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Mikel Echeverria - Backend & Full Stack Engineer"
    description="Portafolio profesional de Mikel Echeverria, Backend & Full Stack Engineer especializado en arquitectura de APIs, sistemas escalables e IA."
/>
<main
    class="max-w-3xl mx-auto px-6 text-zinc-900 transition-colors duration-300 dark:text-zinc-100"
>
    <SectionContainer class="pt-32 pb-20 sm:pt-48 sm:pb-32 lg:pt-64 lg:pb-40">
        <div class="flex flex-col items-start gap-y-12">
            <div class="flex items-center gap-x-8">
                <div
                    id="hero-avatar-anchor"
                    class="relative size-28 shrink-0 rounded-[28px] sm:size-36"
                >
                    <img
                        id="hero-avatar-fallback"
                        class="size-full rounded-[28px] object-cover object-center shadow-2xl shadow-zinc-900/20 dark:shadow-black/40"
                        src="/photo.webp"
                        alt="Mikel Echeverria, Desarrollador Full Stack y Backend"
                        width="288"
                        height="288"
                        loading="eager"
                    />
                </div>
                <div class="space-y-2">
                    <h1
                        class="text-4xl sm:text-6xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100"
                    >
                        <span data-i18n="hero.hello">Mikel Echeverria</span>
                    </h1>
                    <div
                        class="flex items-center gap-x-2.5 text-[13px] font-semibold tracking-wide text-emerald-600 dark:text-emerald-400/90"
                    >
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
                            ></span>
                        </span>
                        <span
                            data-i18n="badge.available"
                            class="uppercase tracking-widest"
                            >Disponible para trabajar</span
                        >
                    </div>
                </div>
            </div>

            <div class="max-w-2xl space-y-8">
                <p
                    class="text-xl sm:text-2xl font-medium leading-relaxed text-zinc-600 dark:text-zinc-400 text-pretty"
                    data-i18n="hero.description"
                >
                    Backend & Full Stack Engineer. Especializado en arquitectura
                    de APIs robustas, sistemas escalables y automatización
                    inteligente.
                </p>
            </div>

            <nav class="flex flex-wrap gap-x-8 gap-y-4">
                <a
                    href="https://github.mikeldev.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-x-2 text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group"
                >
                    <GitHubIcon
                        class="size-4 opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                    <span>GitHub</span>
                </a>
                <a
                    href="https://www.linkedin.com/in/mikel-echeverria"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-x-2 text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group"
                >
                    <LinkedInIcon
                        class="size-4 opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                    <span>LinkedIn</span>
                </a>
                <a
                    href="mailto:mikel@mikeldev.com"
                    class="flex items-center gap-x-2 text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group"
                >
                    <MailIcon
                        class="size-4 opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                    <span>Email</span>
                </a>
            </nav>
        </div>
    </SectionContainer>

    <SectionContainer id="experiencia" class="py-24 sm:py-40">
        <h2
            class="text-3xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-12"
            data-i18n="nav.experience"
        >
            Experiencia
        </h2>
        <Experiences />
    </SectionContainer>

    <SectionContainer id="proyectos" class="py-24 sm:py-40 lg:py-48">
        <h2
            class="text-3xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-12"
            data-i18n="nav.projects"
        >
            Proyectos
        </h2>
        <Projects />
    </SectionContainer>

    <SectionContainer id="sobre-mi" class="py-24 sm:py-40 lg:py-48">
        <h2
            class="text-3xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100 mb-12"
            data-i18n="nav.about"
        >
            Sobre mí
        </h2>
        <AboutMe />
    </SectionContainer>

    <ScrollTopButton />
    <Footer />
</main>
