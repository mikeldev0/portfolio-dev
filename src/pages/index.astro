---
import AboutMe from "../components/AboutMe.astro";
import Badge from "../components/Badge.astro";
import Experiences from "../components/Experiences.astro";
import HolidayProfileImage from "../components/HolidayProfileImage";
import Footer from "../components/Footer.astro";
import ProfileCheck from "../components/ProfileCheck.astro";
import Proyects from "../components/Proyects.astro";
import ScrollTopButton from "../components/ScrollTopButton.astro";
import SectionContainer from "../components/SectionContainer.astro";
import SocialPill from "../components/SocialPill.astro";
import TextAnimatedGradient from "../components/TextAnimatedGradient";
import BriefcaseIcon from "../icons/BriefcaseIcon.astro";
import Code from "../icons/Code.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import LinkedInIcon from "../icons/LinkedInIcon.astro";
import MailIcon from "../icons/MailIcon.astro";
import XIcon from "../icons/XIcon.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Mikel Echeverria - Desarrollador Full Stack & Backend en Pamplona | mikeldev.com"
	description="Portafolio de Mikel Echeverria, desarrollador Full Stack y Backend de Pamplona, España. Especializado en aplicaciones multiplataforma, diseño web, y soluciones tecnológicas innovadoras."
/>
<main class="max-w-[screen-sm] px-4 md:px-8 lg:px-16  text-gray-900  transition-colors duration-300">
	<SectionContainer class="pt-16 pb-12 sm:pt-32 sm:pb-20 lg:pt-44 lg:pb-24">
		<div
			class="flex flex-col items-center sm:items-start sm:flex-row sm:gap-x-4"
		>
                        <HolidayProfileImage className="mb-4 sm:mb-0 lg:mb-4" client:load />
			<div
				class="flex flex-col lg:flex-row gap-x-4 items-center sm:items-start"
			>
                                <h1
                                        class="text-3xl sm:text-4xl font-bold mb-4 text-center sm:text-left lg:mt-9 text-gray-900 dark:text-gray-100"
                                >
                                        <span data-i18n="hero.hello">Hola! soy</span>
                                        <TextAnimatedGradient fontSize="inherit"
                                                >Mikel</TextAnimatedGradient
                                        >
                                </h1>
				<a
					href="https://www.linkedin.com/in/mikel-echeverria"
					target="_blank"
					rel="noopener noreferrer"
                                        class="lg:mt-11"
                                >
                                        <Badge>
											<span data-i18n="badge.available">
												Disponible para trabajar
											</span>
										</Badge>
                                </a>
			</div>
		</div>

                <h2
                        class="text-xl sm:text-2xl text-wrap mt-4 sm:mt-0 text-center sm:text-left"
                >
                        <span data-i18n="hero.description" class="text-gray-900 dark:text-gray-100 opacity-80">Desarrollador Backend y Full Stack en Pamplona, España. Construyo APIs, interfaces web y automatizaciones con foco en arquitectura limpia, datos fiables e inteligencia artificial aplicada.</span>
                </h2>

                <ul class="mt-6 flex max-w-3xl flex-wrap justify-center gap-2 sm:justify-start">
                        <li class="rounded-full border border-zinc-300 bg-white px-3 py-1 text-sm font-medium text-zinc-800 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100" data-i18n="hero.signalBackend">
                                Backend y APIs
                        </li>
                        <li class="rounded-full border border-zinc-300 bg-white px-3 py-1 text-sm font-medium text-zinc-800 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100" data-i18n="hero.signalFullStack">
                                Full stack web
                        </li>
                        <li class="rounded-full border border-zinc-300 bg-white px-3 py-1 text-sm font-medium text-zinc-800 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100" data-i18n="hero.signalAi">
                                IA y automatización
                        </li>
                        <li class="rounded-full border border-zinc-300 bg-white px-3 py-1 text-sm font-medium text-zinc-800 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100" data-i18n="hero.signalData">
                                SQL y modelos de datos
                        </li>
                </ul>

		<ul class="flex flex-wrap justify-center sm:justify-start gap-4 mt-8">
			<li>
				<SocialPill
					perfilPill
					href="https://github.mikeldev.com"
					title="Perfil de Github de Mikel Echeverria"
				>
					<GitHubIcon class="size-5 sm:size-6" />
				</SocialPill>
			</li>
			<li>
				<SocialPill
					href="https://www.linkedin.com/in/mikel-echeverria"
					title="Perfil de LinkedIn de Mikel Echeverria"
				>
					<LinkedInIcon class="size-5 sm:size-6" />
				</SocialPill>
			</li>
			<li>
				<SocialPill
					href="https://x.com/MikelEcheve"
					title="Perfil de X de Mikel Echeverria"
				>
					<XIcon class="size-5 sm:size-6" />
				</SocialPill>
			</li>
			<li>
				<SocialPill
					href="mailto:mikel@mikeldev.com"
					title="Enviar correo a Mikel Echeverria"
				>
					<MailIcon class="size-5 sm:size-6" />
					<span class="text-gray-800 dark:text-gray-200">mikel@mikeldev.com</span>
				</SocialPill>
			</li>
		</ul>
	</SectionContainer>

	<SectionContainer class="py-16 sm:py-32 text-gray-900 dark:text-gray-100">
                <h2 id="experiencia" class="text-2xl font-bold mb-6 flex gap-x-2 " data-i18n="section.experience">
                        <BriefcaseIcon class="size-7" />
                        Experiencia laboral
                </h2>
		<Experiences />
	</SectionContainer>

	<SectionContainer class="py-16 sm:py-32 lg:py-44 text-gray-900 dark:text-gray-100">
                <h2 id="proyectos" class="text-2xl font-bold mb-6 flex gap-x-2" data-i18n="section.projects">
                        <Code class="size-7" />
                        Proyectos
                </h2>
		<Proyects />
	</SectionContainer>

	<SectionContainer class="py-16 sm:py-32 lg:py-44 text-gray-900 dark:text-gray-100">
                <h2 id="sobre-mi" class="text-2xl font-bold mb-6 flex gap-x-2" data-i18n="section.about">
                        <ProfileCheck class="size-7" />
                        Sobre mí
                </h2>
		<AboutMe />
	</SectionContainer>

	<ScrollTopButton />
	<Footer />
</main>
