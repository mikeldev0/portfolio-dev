---
import AboutMe from "../components/AboutMe.astro";
import Experiences from "../components/Experiences.astro";
import HolidayProfileImage from "../components/HolidayProfileImage";
import Footer from "../components/Footer.astro";
import Projects from "../components/Projects.astro";
import ScrollTopButton from "../components/ScrollTopButton.astro";
import SectionContainer from "../components/SectionContainer.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import LinkedInIcon from "../icons/LinkedInIcon.astro";
import MailIcon from "../icons/MailIcon.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Mikel Echeverria - Backend & Full Stack Engineer"
	description="Portafolio profesional de Mikel Echeverria, Backend & Full Stack Engineer especializado en arquitectura de APIs, sistemas escalables e IA."
/>
<main class="max-w-3xl mx-auto px-6 text-zinc-900 transition-colors duration-300 dark:text-zinc-100">
	<SectionContainer class="pt-24 pb-16 sm:pt-40 sm:pb-24 lg:pt-52 lg:pb-32">
		<div class="flex flex-col items-start gap-y-8">
            <div class="flex items-center gap-x-6">
                <HolidayProfileImage className="w-20 h-20 sm:w-24 sm:h-24 grayscale hover:grayscale-0 transition-all duration-500" client:load />
                <div>
                    <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
                        <span data-i18n="hero.hello">Mikel Echeverria</span>
                    </h1>
                    <div class="mt-2 flex items-center gap-x-2 text-xs font-medium text-emerald-600 dark:text-emerald-400">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        <span data-i18n="badge.available">Disponible para trabajar</span>
                    </div>
                </div>
            </div>
            
            <div class="max-w-2xl">
                <p class="text-xl sm:text-2xl font-normal leading-relaxed text-zinc-600 dark:text-zinc-400 text-pretty" data-i18n="hero.description">
                    Backend & Full Stack Engineer. Especializado en arquitectura de APIs robustas, sistemas escalables y automatización inteligente.
                </p>

                <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-[13px] font-medium text-zinc-400 dark:text-zinc-500">
                    <span data-i18n="hero.signalBackend">Backend Architecture</span>
                    <span class="hidden sm:inline">/</span>
                    <span data-i18n="hero.signalFullStack">Full Stack Delivery</span>
                    <span class="hidden sm:inline">/</span>
                    <span data-i18n="hero.signalAi">AI & Automation</span>
                    <span class="hidden sm:inline">/</span>
                    <span data-i18n="hero.signalData">Data Engineering</span>
                </div>
            </div>

            <nav class="flex flex-wrap gap-x-6 gap-y-3 mt-4">
                <a
                    href="https://github.mikeldev.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-x-2 text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
                >
                    <GitHubIcon class="size-4" />
                    <span>GitHub</span>
                </a>
                <a
                    href="https://www.linkedin.com/in/mikel-echeverria"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-x-2 text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
                >
                    <LinkedInIcon class="size-4" />
                    <span>LinkedIn</span>
                </a>
                <a
                    href="mailto:mikel@mikeldev.com"
                    class="flex items-center gap-x-2 text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
                >
                    <MailIcon class="size-4" />
                    <span>mikel@mikeldev.com</span>
                </a>
            </nav>
		</div>
	</SectionContainer>

	<SectionContainer class="py-20 sm:py-32">
        <h2 id="experiencia" class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500 mb-12" data-i18n="section.experience">
            Experiencia laboral
        </h2>
		<Experiences />
	</SectionContainer>

	<SectionContainer class="py-20 sm:py-32 lg:py-40">
        <h2 id="proyectos" class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500 mb-12" data-i18n="section.projects">
            Proyectos
        </h2>
		<Projects />
	</SectionContainer>

	<SectionContainer class="py-20 sm:py-32 lg:py-40">
        <h2 id="sobre-mi" class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500 mb-12" data-i18n="section.about">
            Sobre mí
        </h2>
		<AboutMe />
	</SectionContainer>

	<ScrollTopButton />
	<Footer />
</main>
