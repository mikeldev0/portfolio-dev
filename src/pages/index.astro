---
import AboutMe from "../components/AboutMe.astro";
import Experiences from "../components/Experiences.astro";
import HolidayProfileImage from "../components/HolidayProfileImage";
import Footer from "../components/Footer.astro";
import Projects from "../components/Projects.astro";
import ScrollTopButton from "../components/ScrollTopButton.astro";
import SectionContainer from "../components/SectionContainer.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import LinkedInIcon from "../icons/LinkedInIcon.astro";
import MailIcon from "../icons/MailIcon.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Mikel Echeverria - Backend & Full Stack Engineer"
    description="Portafolio profesional de Mikel Echeverria, Backend & Full Stack Engineer especializado en arquitectura de APIs, sistemas escalables e IA."
/>
<main
    class="max-w-4xl mx-auto px-6 text-zinc-900 transition-colors duration-300 dark:text-zinc-100"
>
    <SectionContainer class="pt-32 pb-20 sm:pt-48 sm:pb-32 lg:pt-64 lg:pb-40">
        <div class="flex flex-col items-start gap-y-12">
            <div class="flex items-center gap-x-8">
                <HolidayProfileImage
                    className="w-24 h-24 sm:w-28 sm:h-28 shadow-2xl dark:shadow-zinc-900/50 rounded-full transition-transform duration-500 hover:scale-105"
                    client:load
                />
                <div class="space-y-2">
                    <h1
                        class="text-4xl sm:text-6xl font-bold tracking-tighter text-zinc-900 dark:text-zinc-100"
                    >
                        <span data-i18n="hero.hello">Mikel Echeverria</span>
                    </h1>
                    <div class="inline-flex items-center gap-x-2 rounded-full border border-zinc-200/60 bg-zinc-50/50 px-3 py-1 text-sm font-medium text-zinc-700 dark:border-zinc-800/60 dark:bg-zinc-900/50 dark:text-zinc-300 shadow-sm mt-1">
                        <span class="flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        <span data-i18n="badge.available">Disponible para trabajar</span>
                    </div>
                </div>
            </div>

            <div class="max-w-2xl space-y-8">
                <p
                    class="text-xl sm:text-2xl font-medium leading-relaxed text-zinc-600 dark:text-zinc-400 text-pretty"
                    data-i18n="hero.description"
                >
                    Backend & Full Stack Engineer. Especializado en arquitectura
                    de APIs robustas, sistemas escalables y automatización
                    inteligente.
                </p>

                
            </div>

            <nav class="flex flex-wrap gap-x-8 gap-y-4 mt-4">
                <a
                    href="https://github.mikeldev.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-x-2 text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group"
                >
                    <GitHubIcon
                        class="size-4 opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                    <span>GitHub</span>
                </a>
                <a
                    href="https://www.linkedin.com/in/mikel-echeverria"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-x-2 text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group"
                >
                    <LinkedInIcon
                        class="size-4 opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                    <span>LinkedIn</span>
                </a>
                <a
                    href="mailto:mikel@mikeldev.com"
                    class="flex items-center gap-x-2 text-sm font-semibold text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors group"
                >
                    <MailIcon
                        class="size-4 opacity-70 group-hover:opacity-100 transition-opacity"
                    />
                    <span>Email</span>
                </a>
            </nav>
        </div>
    </SectionContainer>

    <SectionContainer class="py-24 sm:py-40">
        <h2
            id="experiencia"
            class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-12"
            data-i18n="section.experience"
        >
            Experiencia laboral
        </h2>
        <Experiences />
    </SectionContainer>

    <SectionContainer class="py-24 sm:py-40 lg:py-48">
        <h2
            id="proyectos"
            class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-12"
            data-i18n="section.projects"
        >
            Proyectos seleccionados
        </h2>
        <Projects />
    </SectionContainer>

    <SectionContainer class="py-24 sm:py-40 lg:py-48">
        <h2
            id="sobre-mi"
            class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-12"
            data-i18n="section.about"
        >
            Sobre mí
        </h2>
        <AboutMe />
    </SectionContainer>

    <ScrollTopButton />
    <Footer />
</main>
