---
import "@fontsource-variable/onest";
import Background from "../components/Background.astro";
import Header from "../components/Header.astro";
import ScrollLinkedAvatar from "../components/ScrollLinkedAvatar";
import Snowfall from "../components/Snowfall";
import { env } from "../lib/env";

interface Props {
  title: string;
  description: string;
}

const { description, title } = Astro.props;
const { enableHolidayEffects } = env;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Mikel Echeverria",
  alternateName: "mikedev",
  jobTitle: "Desarrollador Full Stack y Backend",
  url: "https://www.mikeldev.com",
  image: "https://www.mikeldev.com/img/mikel-echeverria.jpg",
  sameAs: [
    "https://github.com/mikeldev0",
    "https://www.linkedin.com/in/mikel-echeverria",
    "https://x.com/MikelEcheve",
    "mailto:mikel@mikeldev.com",
  ],
  description:
    "Desarrollador Full Stack y Backend en Pamplona, España. Especializado en aplicaciones multiplataforma, diseño web y soluciones tecnológicas innovadoras.",
  alumniOf: "Nombre de Tu Universidad",
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta
      name="title"
      content="Mikel Echeverria - Desarrollador Full Stack & Backend en Pamplona | mikeldev.com"
    />
    <link rel="canonical" href="https://www.mikeldev.com" />

    <!-- Open Graph Tags -->
    <meta
      property="og:title"
      content="Mikel Echeverria - Desarrollador Full Stack & Backend en Pamplona"
    />
    <meta
      property="og:description"
      content="Portafolio de Mikel Echeverria, desarrollador Full Stack y Backend de Pamplona, especializado en aplicaciones multiplataforma, diseño web y soluciones innovadoras."
    />
    <meta
      property="og:image"
      content="https://raw.githubusercontent.com/mikeldev0/portfolio-dev/main/public/web_screenshot.webp"
    />
    <meta property="og:url" content="https://www.mikeldev.com" />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Mikel Echeverria - Desarrollador Full Stack & Backend en Pamplona"
    />
    <meta
      name="twitter:description"
      content="Portafolio de Mikel Echeverria, desarrollador Full Stack y Backend especializado en aplicaciones multiplataforma y diseño web innovador."
    />
    <meta name="twitter:image" content="https://www.mikeldev.com/photo.webp" />

    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <Background />
    {enableHolidayEffects && <Snowfall client:load />}
    <Header />
    <ScrollLinkedAvatar client:load />
    <slot />
    <script src="/i18n.js" is:inline></script>
  </body>
</html>

<style is:global>
  :root {
    --bg: oklch(1 0 0);
    --surface: oklch(0.98 0 0);
    --ink: oklch(0.18 0.01 240);
    --ink-muted: oklch(0.45 0.01 240);
    --primary: oklch(0.2 0.01 240); /* Deep Slate */
    --primary-muted: oklch(0.2 0.01 240 / 0.05);
    --accent: oklch(0.55 0.12 240); /* Deep Blue */
    --border: oklch(0.92 0 0);

    color-scheme: light dark;
  }

  .dark {
    --bg: oklch(0.12 0 0); /* Pure Dark */
    --surface: oklch(0.16 0.01 240);
    --ink: oklch(0.92 0 0);
    --ink-muted: oklch(0.65 0 0);
    --primary: oklch(0.98 0 0); /* Pure White */
    --primary-muted: oklch(0.98 0 0 / 0.1);
    --accent: oklch(0.75 0.1 240);
    --border: oklch(0.22 0 0);
  }

  html {
    font-family: "Onest Variable", system-ui, sans-serif;
    background-color: var(--bg);
    color: var(--ink);
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: inherit;
    font-weight: 800;
    line-height: 1.1;
    text-wrap: balance;
    letter-spacing: -0.04em;
  }

  p {
    max-width: 70ch;
    text-wrap: pretty;
  }

  #hero-avatar-fallback {
    transition:
      opacity 180ms ease,
      visibility 180ms ease;
  }

  #header-avatar-fallback {
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 180ms ease,
      visibility 180ms ease;
  }

  .scroll-avatar-ready #hero-avatar-fallback {
    opacity: 0;
    visibility: hidden;
  }

  .scroll-avatar-ready #header-avatar-fallback {
    opacity: 0;
    visibility: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    #hero-avatar-fallback {
      transition: none;
    }
    #header-avatar-fallback {
      opacity: 1;
      visibility: visible;
      transition: none;
    }
  }

  @keyframes blur {
    to {
      backdrop-filter: blur(20px);
      border-color: var(--border);
      background-color: var(--surface);
    }
  }

  #main-header {
    animation: blur linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }
</style>
