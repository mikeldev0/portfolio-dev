---
import "@fontsource-variable/onest";
import Background from "../components/Background.astro";
import Header from "../components/Header.astro";
import ScrollLinkedAvatar from "../components/ScrollLinkedAvatar.astro";
import Snowfall from "../components/Snowfall.astro";
import { env } from "../lib/env";
import { isWithinHolidaySeason } from "../lib/holiday";

interface Props {
  title: string;
  description: string;
}

const { description, title } = Astro.props;
const { enableHolidayEffects } = env;
const showHolidayEffects = enableHolidayEffects && isWithinHolidaySeason();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Mikel Echeverria",
  alternateName: "mikedev",
  jobTitle: "Desarrollador Full Stack y Backend",
  url: "https://www.mikeldev.com",
  image: "https://www.mikeldev.com/photo.webp",
  email: "mailto:mikel@mikeldev.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Pamplona",
    addressRegion: "Navarra",
    addressCountry: "ES",
  },
  knowsAbout: [
    "Backend engineering",
    "Full stack development",
    "API architecture",
    "Django",
    "React",
    "Astro",
    "Spring Boot",
    "SQL",
    "Artificial intelligence",
    "Automation",
  ],
  sameAs: [
    "https://github.com/mikeldev0",
    "https://www.linkedin.com/in/mikel-echeverria",
    "https://x.com/mikelecheve",
    "mailto:mikel@mikeldev.com",
  ],
  description:
    "Backend & Full Stack Engineer en Pamplona, España. Especializado en arquitectura de APIs, sistemas escalables, automatización e inteligencia artificial aplicada.",
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta
      name="title"
      content="Mikel Echeverria - Backend & Full Stack Engineer en Pamplona | mikeldev.com"
    />
    <meta
      name="keywords"
      content="Mikel Echeverria, Backend Engineer, Full Stack Engineer, desarrollador backend Pamplona, desarrollador full stack Navarra, API architecture, Django, React, Astro, Spring Boot, SQL, AI automation"
    />
    <meta name="author" content="Mikel Echeverria" />
    <link rel="canonical" href="https://www.mikeldev.com" />
    <link rel="alternate" hreflang="es" href="https://www.mikeldev.com/" />
    <link rel="alternate" hreflang="en" href="https://www.mikeldev.com/" />
    <link rel="alternate" hreflang="x-default" href="https://www.mikeldev.com/" />

    <!-- Open Graph Tags -->
    <meta
      property="og:title"
      content="Mikel Echeverria - Backend & Full Stack Engineer en Pamplona"
    />
    <meta
      property="og:description"
      content="Portfolio de Mikel Echeverria, Backend & Full Stack Engineer especializado en arquitectura de APIs, sistemas escalables, automatización e IA aplicada."
    />
    <meta property="og:image" content="https://www.mikeldev.com/photo.webp" />
    <meta property="og:url" content="https://www.mikeldev.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mikel Echeverria" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Mikel Echeverria - Backend & Full Stack Engineer en Pamplona"
    />
    <meta
      name="twitter:description"
      content="Portfolio de Mikel Echeverria, Backend & Full Stack Engineer especializado en arquitectura de APIs, sistemas escalables, automatización e IA aplicada."
    />
    <meta name="twitter:image" content="https://www.mikeldev.com/photo.webp" />

    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <Background />
    {showHolidayEffects && <Snowfall />}
    <Header />
    <ScrollLinkedAvatar />
    <slot />
    <script src="/i18n.js" defer is:inline></script>
  </body>
</html>

<style is:global>
  :root {
    --bg: oklch(1 0.003 60); /* Parchment White */
    --surface: oklch(0.97 0.01 60);
    --ink: oklch(0.18 0.01 240);
    --ink-muted: oklch(0.45 0.01 240);
    --primary: oklch(0.2 0 0); /* Pure Dark Slate */
    --primary-muted: oklch(0.2 0 0 / 0.05);
    --accent: oklch(0.65 0.08 60); /* Gold / Bronze accent for light mode */
    --border: oklch(0.9 0.015 60);

    color-scheme: light dark;
  }

  .dark {
    --bg: oklch(0.1 0 0); /* Pure Neutral Dark (main branch style) */
    --surface: oklch(0.14 0 0);
    --ink: oklch(0.92 0 0);
    --ink-muted: oklch(0.6 0 0);
    --primary: oklch(0.98 0 0); /* Pure White */
    --primary-muted: oklch(0.98 0 0 / 0.1);
    --accent: oklch(0.4 0 0); /* Neutral Grey Accent */
    --border: oklch(0.2 0 0);
  }

  html {
    font-family: "Onest Variable", system-ui, sans-serif;
    background-color: var(--bg);
    color: var(--ink);
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-x: clip;
  }

  body {
    min-height: 100vh;
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    overflow-x: clip;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: inherit;
    font-weight: 800;
    line-height: 1.1;
    text-wrap: balance;
    letter-spacing: -0.04em;
  }

  p {
    max-width: 70ch;
    text-wrap: pretty;
  }

  #hero-avatar-fallback,
  #header-avatar-fallback {
    transition:
      opacity 180ms ease,
      visibility 180ms ease;
  }

  #header-avatar-fallback {
    opacity: 0;
    visibility: hidden;
  }

  .scroll-avatar-ready #hero-avatar-fallback,
  .scroll-avatar-ready #header-avatar-fallback {
    opacity: 0;
    visibility: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    #hero-avatar-fallback,
    #header-avatar-fallback {
      transition: none;
    }

    #header-avatar-fallback {
      opacity: 1;
      visibility: visible;
    }
  }

  @keyframes blur {
    to {
      backdrop-filter: blur(20px);
      background-color: oklch(from var(--bg) l 0 h / 0.5);
    }
  }

  #main-header {
    animation: blur linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }
</style>
