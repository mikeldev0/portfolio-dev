---
import Image from "astro/components/Image.astro";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSelector from "./LanguageSelector.astro";
import CloseMenuIcon from "../icons/CloseMenuIcon.astro";
import myPhoto from "/public/photo.webp";

const navItems = [
  {
    title: "Experiencia",
    key: "nav.experience",
    label: "experiencia",
    url: "/#experiencia",
  },
  {
    title: "Proyectos",
    key: "nav.projects",
    label: "proyectos",
    url: "/#proyectos",
  },
  {
    title: "Sobre mí",
    key: "nav.about",
    label: "sobre-mi",
    url: "/#sobre-mi",
  },
  {
    title: "Contacto",
    key: "nav.contact",
    label: "contacto",
    url: "/#contacto",
  },
];
---

<header class="fixed top-0 z-50 w-full h-20 flex items-center" id="main-header">
  <div class="max-w-3xl mx-auto w-full px-6 flex items-center justify-between">
    <nav class="flex items-center gap-x-12">
      <a
        href="/#"
        id="header-avatar-anchor"
        class="relative size-11 shrink-0 rounded-full sm:size-12"
        aria-label="Home"
      >
        <Image
          id="header-avatar-fallback"
          class="size-full rounded-full object-cover object-center shadow-md shadow-[var(--primary-muted)] transition-opacity duration-200"
          src={myPhoto}
          alt=""
          width="96"
          height="96"
          loading="eager"
          densities={[1, 2]}
        />
      </a>

      <div class="hidden md:flex items-center gap-x-10">
        {
          navItems.map((link) => (
            <a
              class="nav-link text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--ink-muted)] transition-colors hover:text-[var(--primary)]"
              href={link.url}
              data-i18n={link.key}
              data-section-id={link.label}
              data-nav-link
            >
              {link.title}
            </a>
          ))
        }
      </div>
    </nav>

    <div class="flex items-center gap-x-6">
      <div class="flex items-center gap-x-4">
        <ThemeToggle />
        <div class="w-px h-4 bg-[var(--border)]"></div>
        <LanguageSelector />
      </div>
      <button
        id="burger-btn"
        aria-label="Abrir menú"
        class="md:hidden p-2 -mr-2 text-[var(--ink)] hover:text-[var(--primary)] transition-colors"
      >
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile nav -->
<div
  id="mobile-nav"
  class="fixed inset-0 bg-[var(--bg)]/98 backdrop-blur-2xl z-[100] flex flex-col items-center justify-center px-6 transition-all duration-500 opacity-0 pointer-events-none translate-y-8"
>
  <button
    id="close-mobile-nav"
    aria-label="Cerrar menú"
    class="absolute top-8 right-8 p-2 text-[var(--ink)] hover:text-[var(--primary)]"
  >
    <CloseMenuIcon class="size-8" />
  </button>

  <div class="flex flex-col gap-y-12 items-center">
    {
      navItems.map((link) => (
        <a
          class="mobile-nav-link max-w-full text-center text-4xl font-bold tracking-tighter text-[var(--ink)] hover:text-[var(--primary)] transition-colors sm:text-5xl"
          href={link.url}
          data-i18n={link.key}
        >
          {link.title}
        </a>
      ))
    }
  </div>
</div>

<style>
  .nav-link {
    transition:
      color 180ms cubic-bezier(0.22, 1, 0.36, 1),
      text-shadow 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    text-shadow:
      -0.018em 0 0 currentColor,
      0.018em 0 0 currentColor;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link {
      transition: none;
    }
  }
</style>

<script>
  function initMobileMenu() {
    const burgerBtn = document.getElementById("burger-btn");
    const closeBtn = document.getElementById("close-mobile-nav");
    const mobileNav = document.getElementById("mobile-nav");
    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");
    const header = document.getElementById("main-header");

    if (!burgerBtn || !mobileNav || !closeBtn) return;

    // Clean up to prevent double listeners
    burgerBtn.replaceWith(burgerBtn.cloneNode(true));
    closeBtn.replaceWith(closeBtn.cloneNode(true));

    const newBurgerBtn = document.getElementById("burger-btn");
    const newCloseBtn = document.getElementById("close-mobile-nav");

    const openMenu = () => {
      mobileNav.classList.remove("opacity-0", "pointer-events-none", "translate-y-8");
      mobileNav.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
    };

    const closeMenu = () => {
      mobileNav.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
      mobileNav.classList.add("opacity-0", "pointer-events-none", "translate-y-8");
    };

    newBurgerBtn?.addEventListener("click", openMenu);
    newCloseBtn?.addEventListener("click", closeMenu);
    mobileNavLinks.forEach((link) => {
      link.replaceWith(link.cloneNode(true));
    });

    // Re-select after cloning
    const newMobileNavLinks = document.querySelectorAll(".mobile-nav-link");
    newMobileNavLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    const handleScroll = () => {
      if (window.scrollY > 20) {
        header?.classList.add("backdrop-blur-xl", "bg-[var(--bg)]/50", "!h-16");
      } else {
        header?.classList.remove("backdrop-blur-xl", "bg-[var(--bg)]/50", "!h-16");
      }
    };

    window.removeEventListener("scroll", handleScroll);
    window.addEventListener("scroll", handleScroll);
  }

  // Initialize on first load and on astro:page-load (if transitions are used)
  document.addEventListener("astro:page-load", initMobileMenu);
  initMobileMenu();

  // Active state logic
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("#main-header a[data-nav-link]");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              if (link.getAttribute("data-section-id") === entry.target.id) {
                link.classList.remove("text-zinc-400", "text-zinc-500");
                link.classList.add("text-zinc-900", "dark:text-zinc-100");
              } else {
                // For desktop links use zinc-400, for mobile use zinc-500 (resting states)
                const isMobile = link.classList.contains("mobile-nav-link");
                link.classList.add(isMobile ? "text-zinc-500" : "text-zinc-400");
                link.classList.remove("text-zinc-900", "dark:text-zinc-100");
              }
            });
          }
        });
      },
      { threshold: 0.3 }
    );

    sections.forEach((s) => observer.observe(s));
  });
</script>
