---
import LanguageArrowIcon from "../icons/LanguageArrowIcon.astro";
---
<div class="relative transition duration-200 ease-in-out group">
    <select
        id="language-selector"
        class="appearance-none bg-transparent text-zinc-500 dark:text-zinc-400 text-[11px] font-bold uppercase tracking-[0.2em] px-2 py-2 pr-6 rounded-md hover:text-zinc-900 dark:hover:text-zinc-100 focus:outline-none cursor-pointer transition-colors"
    >
        <!-- Las opciones se rellenarán dinámicamente en el cliente -->
    </select>
    <LanguageArrowIcon />
</div>

<!-- Inicializa el selector de idioma en el cliente -->
<script is:inline src="/scripts/languageSelector.js"></script>
