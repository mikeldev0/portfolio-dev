---
import GitHubIcon from "../icons/GitHubIcon.astro";

const currentYear = new Date().getFullYear();
---

<footer
  class="mt-20 border-t border-[var(--border)]"
  itemscope
  itemtype="https://schema.org/WPFooter"
>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex flex-col items-center md:items-start gap-2">
        <span class="text-sm font-bold tracking-tight text-[var(--ink)]"> Mikel Echeverria </span>
        <span class="text-xs text-[var(--ink-muted)]" itemprop="copyrightHolder">
          © {currentYear} · <span data-i18n="footer.rights">Todos los derechos reservados</span>
        </span>
      </div>

      <nav aria-label="Footer Navigation">
        <ul
          class="flex items-center gap-x-8 text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--ink-muted)]"
        >
          <li>
            <a
              href="https://github.mikeldev.com/portfolio-dev"
              class="hover:text-[var(--primary)] transition-colors flex items-center gap-x-2"
              itemprop="sameAs"
            >
              <GitHubIcon class="size-4" />
              <span data-i18n="footer.source">Source</span>
            </a>
          </li>
          <li>
            <a
              href="/#sobre-mi"
              class="hover:text-[var(--primary)] transition-colors"
              itemprop="about"
            >
              <span data-i18n="footer.about">Sobre mí</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
