    VB_NET: { name: "VB.NET", color: "bg-purple-500/10 text-purple-700 dark:text-purple-400 border-purple-200 dark:border-purple-900/50" },
    ANDROID: { name: "Android", color: "bg-green-700/10 text-green-700 dark:text-green-400 border-green-200 dark:border-green-900/50" },
    IOS: { name: "iOS", color: "bg-zinc-400/10 text-zinc-700 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700/50" },
