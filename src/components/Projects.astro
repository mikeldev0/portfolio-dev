const STATIC_PROJECTS: Project[] = [
    {
        link: "https://proyectosjs.mikeldev.com",
        title: "Proyectos desarrollados 100% con JavaScript",
        description:
            "Una selección de herramientas y experimentos prácticos construidos con Vanilla JS. Incluye desde lógica de negocio hasta interfaces reactivas y juegos.",
        tags: [TAG.JAVASCRIPT, TAG.HTML, TAG.CSS, TAG.ASTRO],
    },
    {
        title: "Woof & Work Marketing",
        description:
            "Plataforma para agencia de marketing digital especializada en el sector mascotas. Implementación de landing page con enfoque en performance y conversión.",
        tags: [TAG.REACT, TAG.TYPESCRIPT, TAG.CSS],
        link: "https://woofandwork.netlify.app",
    },
    {
        title: "WebLLM-local Chatbot",
        description:
            "Chatbot impulsado por IA que utiliza WebGPU para ejecutar modelos de lenguaje localmente en el navegador. Enfoque en privacidad y cómputo distribuido.",
        github: "/WebLLM-local",
        tags: [TAG.JAVASCRIPT, TAG.HTML, TAG.CSS],
        link: "https://chat.mikeldev.com",
    },
    {
        title: "Hundir la flota - Game Engine",
        description:
            "Motor de juego para el clásico Hundir la Flota desarrollado en Java. Implementación de lógica de colisiones, IA básica y estados de juego.",
        github: "/HundirLaFlota",
        tags: [TAG.JAVA],
    },
    {
        title: "HugChat CLI",
        description:
            "Interfaz de línea de comandos para interactuar con modelos de lenguaje de HuggingFace. Automatización de prompts y gestión de sesiones vía terminal.",
        github: "/HuggingChatCLI",
        tags: [TAG.PYTHON, TAG.BASH, TAG.BATCH],
    },
    {
        title: "Carpooling App Cuatrovientos",
        description:
            "Aplicación móvil de coche compartido para reducir la huella de carbono escolar. Gestión de rutas, usuarios y ahorros de CO2.",
        github: "/BlaBlaCarCuatrovientos",
        tags: [TAG.JAVA, TAG.ANDROID],
    },
];

async function fetchPinnedRepos(username: string): Promise<Project[]> {
    if (!GITHUB_TOKEN) return [];

    try {
        const response = await fetch(GITHUB_URL, {
            method: 'POST',
            headers: {
                'Authorization': `bearer ${GITHUB_TOKEN}`,
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                query: `{
                    user(login: "${username}") {
                        pinnedItems(first: 6, types: REPOSITORY) {
                            nodes {
                                ... on Repository {
                                    name
                                    description
                                    url
                                    homepageUrl
                                    languages(first: 3) {
                                        nodes {
                                            name
                                        }
                                    }
                                    openGraphImageUrl
                                }
                            }
                        }
                    }
                }`
            }),
        });

        if (!response.ok) return [];

        const data = await response.json();
        if (data.errors) return [];

        return data.data.user.pinnedItems.nodes.map((repo: GitHubRepository) => {
            const repoTags = repo.languages.nodes
                .map((lang) => {
                    const tagKey = Object.keys(TAG).find(key =>
                        TAG[key as keyof typeof TAG].name.toLowerCase() === lang.name.toLowerCase()
                    );
                    return tagKey ? TAG[tagKey as keyof typeof TAG] : null;
                })
                .filter(Boolean);

            return {
                title: repo.name,
                description: repo.description || "",
                github: repo.url,
                link: repo.homepageUrl,
                image: repo.openGraphImageUrl,
                tags: repoTags,
            };
        });
    } catch {
        return [];
    }
}

let PROJECTS: Project[] = STATIC_PROJECTS;

try {
    const githubProjects = await fetchPinnedRepos('mikeldev0');
    if (githubProjects && githubProjects.length > 0) {
        PROJECTS = githubProjects;
    }
} catch {
    // Silently fallback to static projects
}

const getRepositoryUrl = (github?: string) => {
    if (!github) return undefined;
    return github.startsWith("http") ? github : `https://github.com/mikeldev0${github}`;
};
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {PROJECTS.slice(0, 6).map(
        ({ title, description, link, github, image, tags }) => {
            const repositoryUrl = getRepositoryUrl(github);

            return (
            <article class="group flex h-full flex-col overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm transition-all hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950">
                {image && (
                    <div class="aspect-video w-full overflow-hidden border-b border-zinc-200 dark:border-zinc-800">
                        <img
                            src={image}
                            alt={title}
                            loading="lazy"
                            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                        />
                    </div>
                )}
                <div class="flex flex-1 flex-col p-6">
                    <div class="flex-1">
                        <h3 class="text-xl font-bold tracking-tight text-zinc-900 dark:text-white">
                            {title}
                        </h3>
                        <div class="mt-3 flex flex-wrap gap-1.5">
                            {tags.map((tag) => (
                                <span
                                    class={`rounded-md border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider ${tag.color}`}
                                >
                                    {tag.name}
                                </span>
                            ))}
                        </div>
                        <p class="mt-4 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                            {description}
                        </p>
                    </div>

                    <div class="mt-8 flex items-center gap-4">
                        {link && (
                            <a
                                href={link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-sm font-semibold text-indigo-600 transition hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300"
                            >
                                <DesktopIcon class="size-4" />
                                <span data-i18n="projectsSection.viewDemo">Ver demo</span>
                            </a>
                        )}
                        {repositoryUrl && (
                            <a
                                href={repositoryUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-sm font-semibold text-zinc-700 transition hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-white"
                            >
                                <GitHubIcon class="size-4" />
                                <span data-i18n="projectsSection.viewOnGitHub">GitHub</span>
                            </a>
                        )}
                    </div>
                </div>
            </article>
        )},
    )}
</div>

{PROJECTS.length > 6 && (
    <div class="mt-12 flex justify-center">
        <SocialPill href="https://github.com/mikeldev0?tab=repositories">
            <span data-i18n="projectsSection.moreProjects">Ver más proyectos</span>
        </SocialPill>
    </div>
)}
