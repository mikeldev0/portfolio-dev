---
import DesktopIcon from "../icons/DesktopIcon.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import SocialPill from "./SocialPill.astro";
import { env } from "../lib/env";

const { githubToken: GITHUB_TOKEN, githubUrl: GITHUB_URL } = env;

interface Project {
    title: string;
    description: string;
    link?: string;
    github?: string;
    image?: string;
    tags: Tag[];
}

interface Tag {
    name: string;
    color: string;
}

interface GitHubRepository {
    name: string;
    description?: string;
    url: string;
    homepageUrl?: string;
    openGraphImageUrl?: string;
    languages: {
        nodes: Array<{ name: string }>;
    };
}

const TAG = {
    JAVA: { name: "Java", color: "bg-red-600/10 text-red-700 dark:text-red-400 border-red-200 dark:border-red-900/50" },
    PYTHON: { name: "Python", color: "bg-blue-400/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-900/50" },
    JAVASCRIPT: { name: "JavaScript", color: "bg-yellow-600/10 text-yellow-700 dark:text-yellow-400 border-yellow-200 dark:border-yellow-900/50" },
    BASH: { name: "Bash", color: "bg-zinc-800/10 text-zinc-700 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700/50" },
    BATCH: { name: "Batch", color: "bg-zinc-600/10 text-zinc-700 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700/50" },
    HTML: { name: "HTML", color: "bg-orange-500/10 text-orange-700 dark:text-orange-400 border-orange-200 dark:border-orange-900/50" },
    CSS: { name: "CSS", color: "bg-blue-600/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-900/50" },
    SASS: { name: "SASS", color: "bg-pink-600/10 text-pink-700 dark:text-pink-400 border-pink-200 dark:border-pink-900/50" },
    TYPESCRIPT: { name: "TypeScript", color: "bg-blue-800/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-900/50" },
    REACT: { name: "React", color: "bg-cyan-400/10 text-cyan-700 dark:text-cyan-400 border-cyan-200 dark:border-cyan-900/50" },
    ANGULAR: { name: "Angular", color: "bg-red-700/10 text-red-700 dark:text-red-400 border-red-200 dark:border-red-900/50" },
    SPRING_BOOT: { name: "Spring Boot", color: "bg-green-600/10 text-green-700 dark:text-green-400 border-green-200 dark:border-green-900/50" },
    NODE_JS: { name: "Node.js", color: "bg-green-500/10 text-green-700 dark:text-green-400 border-green-200 dark:border-green-900/50" },
    EXPRESS: { name: "Express", color: "bg-zinc-500/10 text-zinc-700 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700/50" },
    MYSQL: { name: "MySQL", color: "bg-blue-300/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-900/50" },
    DOCKER: { name: "Docker", color: "bg-blue-700/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-900/50" },
    GITHUB: { name: "GitHub", color: "bg-zinc-800/10 text-zinc-700 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700/50" },
    GITLAB: { name: "GitLab", color: "bg-orange-600/10 text-orange-700 dark:text-orange-400 border-orange-200 dark:border-orange-900/50" },
    JIRA: { name: "Jira", color: "bg-blue-500/10 text-blue-700 dark:text-blue-400 border-blue-200 dark:border-blue-900/50" },
    BDD: { name: "BDD", color: "bg-red-500/10 text-red-700 dark:text-red-400 border-red-200 dark:border-red-900/50" },
