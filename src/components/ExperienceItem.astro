---
import ArrowIcon from "../icons/ArrowIcon.astro";

export interface ExperienceItemProps {
  title: string;
  description: string;
  date: string;
  link: string;
  isFirst?: boolean;
  titleKey?: string;
  descriptionKey?: string;
  dateKey?: string;
  tags?: string[];
}

const { title, description, date, link, descriptionKey, dateKey, tags } =
  Astro.props as ExperienceItemProps;

// Split title to separate role and company if possible
const [role, company] = title.includes("|") ? title.split("|").map((s) => s.trim()) : [title, ""];
---

<article
  class="group relative grid grid-cols-1 md:grid-cols-[180px_1fr] gap-y-4 md:gap-x-12 pb-16 last:pb-0"
>
  <time
    class="text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--ink-muted)] mt-1.5"
    data-i18n={dateKey}
  >
    {date}
  </time>

  <div class="flex flex-col">
    <div class="flex flex-col gap-y-1">
      <h3 class="text-2xl font-bold tracking-tight text-[var(--ink)]">
        {role}
      </h3>
      {
        company && (
          <span class="text-sm font-semibold text-[var(--ink-muted)] italic">{company}</span>
        )
      }
    </div>

    {
      tags && tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-[var(--primary)] bg-[var(--primary-muted)] rounded-md border border-[var(--primary-muted)]">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <div
      class="mt-5 text-[16px] leading-relaxed text-[var(--ink)] text-pretty font-normal opacity-90"
      data-i18n={descriptionKey}
      set:html={description}
    />

    {
      link && (
        <div class="mt-8">
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--ink-muted)] hover:text-[var(--primary)] transition-colors group/link"
          >
            <span data-i18n="experience.moreInfo">Detalles</span>
            <ArrowIcon class="size-3.5 transition-transform group-hover/link:translate-x-1" />
          </a>
        </div>
      )
    }
  </div>
</article>
